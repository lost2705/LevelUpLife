<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#BB86FC"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Developer Tools"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Quick player editing for testing and balancing"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Presets"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnLevel10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Level 10" />

                <Button
                    android:id="@+id/btnGoldGems"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gold + Gems" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnMaxStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Max Stats" />

                <Button
                    android:id="@+id/btnSetPenalty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Set Penalty" />
            </LinearLayout>

            <Button
                android:id="@+id/btnClearPenalty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Remove Penalty" />

            <Button
                android:id="@+id/btnResetDungeonCooldown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Reset Dungeon Cooldown" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identity"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etHeroName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Hero Name"
                android:inputType="textCapWords"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etHeroClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Hero Class"
                android:inputType="textCapWords"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progression"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Level"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etCurrentXp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Current XP"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etXpToNextLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="XP To Next Level"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etTalentPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Talent Points"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resources"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etGold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Gold"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etGems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gems"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etXpPenalty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="XP Penalty"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Combat Stats"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCurrentHp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Current HP"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etMaxHp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Max HP"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etCurrentMana"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Current Mana"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etMaxMana"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Max Mana"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attributes"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etStrength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Strength"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etIntelligence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Intelligence"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />

            <EditText
                android:id="@+id/etDexterity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dexterity"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E" />
        </LinearLayout>

        <Button
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:text="Apply Changes" />
    </LinearLayout>
</ScrollView>